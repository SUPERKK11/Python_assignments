   ],
   "source": [
    "arr=[3,4,5,1,6]\n",
    "i=0\n",
    "j=len(arr)-1\n",
    "while i<j:\n",
    "    if arr[i]>=arr[j]:\n",
    "        arr[i],arr[j]=arr[j],arr[i]\n",
    "        print(arr[i])\n",
    "        print(arr[j])\n",
    "    i=i+1\n",
    "    j=j-1\n",
    "arr\n",
    "    "
   ]
